FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY . .
ARG VITE_WS_URL
ENV VITE_WS_URL=$VITE_WS_URL
RUN npm run build

FROM node:22-alpine
WORKDIR /app
RUN npm install tsx
COPY --from=build /app/dist ./dist
COPY serve.ts ./
CMD ["npx", "tsx", "serve.ts"]
